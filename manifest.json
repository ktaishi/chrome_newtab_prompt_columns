{
    "manifest_version": 3,
    "name": "New Tab Memo Board",
    "version": "1.26.0",
    "description": "Opens a column-style memo board when you open a new tab. Supports tags, Markdown, Obsidian export, OpenAI summary, JSON backup, and web clipping.",
    "action": {
      "default_title": "タブメモに保存",
      "default_icon": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      }
    },
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png",
      "512": "icons/icon512.png"
    },
    "chrome_url_overrides": {
      "newtab": "newtab.html"
    },
    "background": {
      "service_worker": "app/background.js"
    },
    "permissions": [
      "storage",
      "contextMenus",
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "http://127.0.0.1:27123/*",
      "http://localhost:27123/*",
      "https://127.0.0.1:27124/*",
      "https://localhost:27124/*",
      "https://api.openai.com/*",
      "http://*/*",
      "https://*/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
    }
  }
